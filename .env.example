# Supabase (Phase 3 — Pro cloud sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth Web Client ID for the TabNotes mobile PWA.
# Use a "Web application" OAuth client with your deployed origin,
# for example https://tabnotes.atlaspcsupport.com.
VITE_GOOGLE_CLIENT_ID=

# Production PWA deployment under https://tabnotes.atlaspcsupport.com/app/
VITE_BASE_PATH=/app/
VITE_TABNOTES_MOBILE_ENTRY=true

# Stripe (Phase 4 — monetization)
VITE_STRIPE_PUBLISHABLE_KEY=
